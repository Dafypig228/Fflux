<Window x:Class="FluxCore.Swarm.UI.ScreenAgentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenAgent - Working in VM"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Foreground="White"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Modern Dark Theme Styles -->
        <Style x:Key="ChatBubbleUser" TargetType="Border">
            <Setter Property="Background" Value="#4C566A"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="50,4,8,4"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <Style x:Key="ChatBubbleAgent" TargetType="Border">
            <Setter Property="Background" Value="#3B4252"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="8,4,50,4"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#5E81AC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#81A1C1"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#88C0D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#BF616A"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D08770"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>

        <!-- Header / Status Bar -->
        <Border Grid.Row="0" Background="#2E3440" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status Indicator -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse x:Name="StatusLight" Width="12" Height="12" Fill="#A3BE8C" Margin="0,0,10,0"/>
                    <TextBlock x:Name="StatusText" Text="ScreenAgent Active" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Current Task -->
                <TextBlock Grid.Column="1" x:Name="CurrentTaskText"
                           Text="Waiting for tasks..."
                           FontSize="12"
                           Foreground="#88C0D0"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- Control Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="PauseButton" Content="⏸ Pause" Style="{StaticResource ModernButton}" Margin="0,0,8,0" Click="PauseButton_Click"/>
                    <Button x:Name="StopButton" Content="⏹ Stop" Style="{StaticResource StopButton}" Click="StopButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Live VM Screenshot Area -->
        <Border Grid.Row="1" Background="#11111B" Margin="16,8" CornerRadius="8">
            <Grid>
                <!-- Screenshot Display -->
                <Image x:Name="ScreenshotImage"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- Loading Overlay -->
                <Border x:Name="LoadingOverlay"
                        Background="#80000000"
                        Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Connecting to VM..."
                                   FontSize="18"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <ProgressBar IsIndeterminate="True"
                                     Width="200"
                                     Height="4"
                                     Margin="0,16,0,0"
                                     Background="#3B4252"
                                     Foreground="#88C0D0"/>
                    </StackPanel>
                </Border>

                <!-- No Screenshot Placeholder -->
                <TextBlock x:Name="NoScreenshotText"
                           Text="No screenshot available"
                           FontSize="16"
                           Foreground="#6272A4"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Visible"/>
            </Grid>
        </Border>

        <!-- Action Log / What ScreenAgent is doing -->
        <Border Grid.Row="2" Background="#2E3440" Padding="16,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Last Action: " FontWeight="SemiBold" Foreground="#88C0D0"/>
                <TextBlock x:Name="LastActionText" Text="None" Foreground="#ECEFF4"/>
            </StackPanel>
        </Border>

        <!-- Chat Panel -->
        <Grid Grid.Row="3" Background="#1E1E2E">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Chat Messages -->
            <ScrollViewer x:Name="ChatScrollViewer"
                          Grid.Row="0"
                          VerticalScrollBarVisibility="Auto"
                          Margin="8">
                <StackPanel x:Name="ChatMessages"/>
            </ScrollViewer>

            <!-- Chat Input -->
            <Border Grid.Row="1" Background="#2E3440" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="ChatInput"
                             Grid.Column="0"
                             Background="#3B4252"
                             Foreground="White"
                             BorderThickness="0"
                             Padding="12,10"
                             FontSize="14"
                             VerticalContentAlignment="Center"
                             Text=""
                             KeyDown="ChatInput_KeyDown">
                        <TextBox.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Button x:Name="SendButton"
                            Grid.Column="1"
                            Content="Send"
                            Style="{StaticResource ModernButton}"
                            Margin="8,0,0,0"
                            Click="SendButton_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
