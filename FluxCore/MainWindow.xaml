<Window x:Class="FluxCore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fluxoria"
        Width="340"
        SizeToContent="Height" 
        MinHeight="180" MaxHeight="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False" 
        ResizeMode="CanResizeWithGrip"
        Opacity="1" 
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Clean minimal button -->
        <Style x:Key="CleanBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#15FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#25FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab button style -->
        <Style x:Key="TabBtn" TargetType="Button" BasedOn="{StaticResource CleanBtn}">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <!-- Glass textbox -->
        <Style x:Key="GlassBox" TargetType="TextBox">
            <Setter Property="Background" Value="#10000000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="#00FFD1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Neon checkbox -->
        <Style x:Key="NeonCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="box" Width="14" Height="14" CornerRadius="3" BorderBrush="#00FFD1" BorderThickness="1" Background="Transparent" Margin="0,0,6,0">
                                <Path x:Name="check" Data="M 2,7 L 5,10 L 12,2" Stroke="#00FFD1" StrokeThickness="1.5" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="box" Property="Background" Value="#2000FFD1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider style -->
        <Style x:Key="NeonSlider" TargetType="Slider">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Window.Resources>

    <!-- Main container with blur effect -->
    <Border x:Name="MainBorder" BorderThickness="1" BorderBrush="#25FFFFFF" CornerRadius="10" Padding="10" MouseLeftButtonDown="OnDrag">
        <Border.Background>
            <SolidColorBrush x:Name="TintBrush" Color="#F0101015"/>
        </Border.Background>
        <Border.Effect>
            <BlurEffect x:Name="BackgroundBlur" Radius="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#00FFD1" Margin="0,0,6,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#00FFD1" BlurRadius="4" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock x:Name="TitleText" Text="FLUXORIA" Foreground="White" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnMic" Content="🎤" Style="{StaticResource CleanBtn}" Click="Btn_Mic_Click" Foreground="#00FFD1" ToolTip="Toggle Microphone"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="⚙" Click="ToggleSettings_Click" Width="24" Height="24" Padding="0" Style="{StaticResource CleanBtn}" ToolTip="Settings"/>
                    <Button Content="─" Click="Btn_Minimize_Click" Width="24" Height="24" Padding="0" Style="{StaticResource CleanBtn}" ToolTip="Minimize"/>
                    <Button Content="✕" Click="Btn_Exit_Click" Width="24" Height="24" Padding="0" Style="{StaticResource CleanBtn}" Foreground="#FF5555"/>
                </StackPanel>
            </Grid>

            <!-- STATUS BAR -->
            <Border Grid.Row="1" Margin="0,8,0,4">
                <StackPanel>
                    <TextBlock x:Name="StatusText" Text="Ready" Foreground="#50FFFFFF" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center"/>
                    
                    <!-- TAB NAVIGATION -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                        <Button x:Name="TabChat" Content="💬 Chat" Style="{StaticResource TabBtn}" Click="Tab_Chat_Click" Foreground="#00FFD1"/>
                        <Button x:Name="TabMemory" Content="🧠 Memory" Style="{StaticResource TabBtn}" Click="Tab_Memory_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- SETTINGS PANEL -->
            <Border x:Name="SettingsPanel" Grid.Row="2" Visibility="Collapsed" Background="#10FFFFFF" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                <StackPanel>
                    <!-- Opacity slider -->
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Opacity" Foreground="#80FFFFFF" FontSize="9" Width="50" VerticalAlignment="Center"/>
                        <Slider x:Name="SliderOpacity" Style="{StaticResource NeonSlider}" Minimum="0.3" Maximum="1" Value="0.95" ValueChanged="SliderOpacity_Changed"/>
                    </DockPanel>

                    <!-- Blur slider -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Blur" Foreground="#80FFFFFF" FontSize="9" Width="50" VerticalAlignment="Center"/>
                        <Slider x:Name="SliderBlur" Style="{StaticResource NeonSlider}" Minimum="0" Maximum="30" Value="10" ValueChanged="SliderBlur_Changed"/>
                    </DockPanel>

                    <!-- Wake word -->
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Name" Foreground="#80FFFFFF" FontSize="9" Width="50" VerticalAlignment="Center"/>
                        <TextBox x:Name="NameBox" Text="Fluxoria" Style="{StaticResource GlassBox}" FontSize="11" TextChanged="NameBox_TextChanged"/>
                    </DockPanel>

                    <!-- Checkboxes -->
                    <CheckBox x:Name="WakeWordCheck" Content="Require wake word" IsChecked="True" Style="{StaticResource NeonCheck}" Margin="0,0,0,4" Checked="WakeWord_Changed" Unchecked="WakeWord_Changed"/>
                    <CheckBox x:Name="AutoMinimizeCheck" Content="Auto-minimize on complete" IsChecked="True" Style="{StaticResource NeonCheck}" Margin="0,0,0,6" Checked="AutoMinimize_Changed" Unchecked="AutoMinimize_Changed"/>

                    <!-- Useful buttons -->
                    <UniformGrid Columns="3" Margin="0,4,0,0">
                        <Button Content="📋 Logs" Style="{StaticResource CleanBtn}" Click="Btn_ShowLogs_Click" FontSize="9"/>
                        <Button Content="🗑️ Clear" Style="{StaticResource CleanBtn}" Click="Btn_ClearChat_Click" FontSize="9"/>
                        <Button Content="🔄 Reset" Style="{StaticResource CleanBtn}" Click="Btn_ResetAudio_Click" FontSize="9" ToolTip="Reset Audio"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- CHAT LIST -->
            <ListView x:Name="ChatList" Grid.Row="3" 
                      Background="Transparent" 
                      BorderThickness="0" 
                      Margin="0,2,0,0"
                      Padding="2,2,2,30" 
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.CanContentScroll="False">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8" Padding="8,6" Margin="0,0,10,0" MaxWidth="280">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Setter Property="Background" Value="#12FFFFFF"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Background" Value="#2500FFD1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <TextBlock Text="{Binding Text}" 
                                     TextWrapping="Wrap" 
                                     Foreground="#E8E8E8" 
                                     FontSize="11" 
                                     FontFamily="Segoe UI"/>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- MEMORY PANEL -->
            <Border x:Name="MemoryPanel" Grid.Row="3" Visibility="Collapsed" Background="#08FFFFFF" CornerRadius="6" Margin="0,2,0,0" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="🧠 Memory Bank" Foreground="#00FFD1" FontWeight="Bold" FontSize="10" Margin="0,0,0,6"/>
                    <ListView x:Name="MemoryList" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="10">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#10FFFFFF" CornerRadius="4" Padding="6" Margin="0,1">
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="#D0D0D0" FontSize="10"/>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- INPUT BOX -->
            <Border Grid.Row="4" Background="#12FFFFFF" CornerRadius="10" Padding="2" Margin="0,4,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="InputBox" Style="{StaticResource GlassBox}" FontSize="11"/>
                    <Button Grid.Column="1" Content="➤" Click="Btn_Send_Click" Style="{StaticResource CleanBtn}" Foreground="#00FFD1" Width="30" Height="30" Padding="0"/>
                </Grid>
            </Border>

            <!-- LOG OVERLAY -->
            <Grid x:Name="LogOverlay" Grid.RowSpan="5" Visibility="Collapsed" Background="#F0050505">
                <Border Background="#101010" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="6" Margin="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="8">
                            <TextBlock Text="LOGS" Foreground="#00FFD1" FontWeight="Bold" FontSize="10" VerticalAlignment="Center"/>
                            <Button Content="✕" Click="Btn_CloseLogs_Click" HorizontalAlignment="Right" Style="{StaticResource CleanBtn}" Foreground="#FF5555"/>
                        </DockPanel>
                        <TextBox x:Name="LogTextBox" Grid.Row="1" Background="Transparent" Foreground="#999999" BorderThickness="0" 
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="8" IsReadOnly="True" FontFamily="Consolas" FontSize="9"/>
                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>