<Window x:Class="FluxCore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Davos"
        Width="340"
        SizeToContent="Height" 
        MinHeight="180" MaxHeight="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False" 
        ResizeMode="CanResizeWithGrip"
        Opacity="1" 
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Clean minimal button -->
        <Style x:Key="CleanBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#15FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#25FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab button style -->
        <Style x:Key="TabBtn" TargetType="Button" BasedOn="{StaticResource CleanBtn}">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>

        <!-- Glass textbox -->
        <Style x:Key="GlassBox" TargetType="TextBox">
            <Setter Property="Background" Value="#10000000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="CaretBrush" Value="#00FFD1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Neon checkbox -->
        <Style x:Key="NeonCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="box" Width="14" Height="14" CornerRadius="3" BorderBrush="#00FFD1" BorderThickness="1" Background="Transparent" Margin="0,0,6,0">
                                <Path x:Name="check" Data="M 2,7 L 5,10 L 12,2" Stroke="#00FFD1" StrokeThickness="1.5" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="box" Property="Background" Value="#2000FFD1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Slider style -->
        <Style x:Key="NeonSlider" TargetType="Slider">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
    </Window.Resources>

    <!-- Main container - BLUR FIX: Separate background and content layers -->
    <Border x:Name="MainBorder" BorderThickness="1" BorderBrush="#25FFFFFF" CornerRadius="10" MouseLeftButtonDown="OnDrag">
        <Grid>
            <!-- BACKGROUND LAYER - This gets blurred (behind content) -->
            <Border x:Name="BlurredBackground" CornerRadius="10">
                <Border.Background>
                    <SolidColorBrush x:Name="TintBrush" Color="#F0101015"/>
                </Border.Background>
                <Border.Effect>
                    <BlurEffect x:Name="BackgroundBlur" Radius="0"/>
                </Border.Effect>
            </Border>

            <!-- CONTENT LAYER - Stays sharp (on top) -->
            <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="6" Height="6" Fill="#00FFD1" Margin="0,0,6,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#00FFD1" BlurRadius="4" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock x:Name="TitleText" Text="DAVOS" Foreground="White" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center" FontSize="11"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnMic" Content="🎤" Style="{StaticResource CleanBtn}" Click="Btn_Mic_Click" Foreground="#00FFD1" ToolTip="Toggle Microphone"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="⚙" Click="ToggleSettings_Click" Width="24" Height="24" Padding="0" Style="{StaticResource CleanBtn}" ToolTip="Settings"/>
                    <Button Content="─" Click="Btn_Minimize_Click" Width="24" Height="24" Padding="0" Style="{StaticResource CleanBtn}" ToolTip="Minimize"/>
                    <Button Content="✕" Click="Btn_Exit_Click" Width="24" Height="24" Padding="0" Style="{StaticResource CleanBtn}" Foreground="#FF5555"/>
                </StackPanel>
            </Grid>

            <!-- STATUS BAR -->
            <Border Grid.Row="1" Margin="0,8,0,4">
                <StackPanel>
                    <TextBlock x:Name="StatusText" Text="Ready" Foreground="#50FFFFFF" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center"/>

                    <!-- TAB NAVIGATION -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                        <Button x:Name="TabChat" Content="💬 Chat" Style="{StaticResource TabBtn}" Click="Tab_Chat_Click" Foreground="#00FFD1"/>
                        <Button x:Name="TabMemory" Content="🧠 Memory" Style="{StaticResource TabBtn}" Click="Tab_Memory_Click"/>
                        <Button x:Name="TabTasks" Content="⚡ Tasks" Style="{StaticResource TabBtn}" Click="Tab_Tasks_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- NEURO HUD PANEL - AI status display -->
            <Border x:Name="NeuroHudPanel" Grid.Row="2" Visibility="Collapsed"
                    Background="#15FFFFFF" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                <StackPanel>
                    <DockPanel>
                        <Ellipse x:Name="HudStateLight" Width="8" Height="8" Fill="#00FFD1" Margin="0,0,6,0"/>
                        <TextBlock x:Name="HudStateText" Text="READY" Foreground="#00FFD1" FontWeight="Bold" FontSize="10"/>
                        <Border x:Name="HudValidationBadge" HorizontalAlignment="Right"
                                Background="#2000FF00" CornerRadius="4" Padding="4,2" Visibility="Collapsed">
                            <TextBlock Text="✓ VERIFIED" Foreground="#00FF00" FontSize="9"/>
                        </Border>
                    </DockPanel>
                    <TextBlock x:Name="HudContentText" Text="" Foreground="#80FFFFFF" FontSize="9"
                               TextWrapping="Wrap" Margin="14,4,0,0"/>
                    <Border x:Name="HudActionBox" Background="#10FFFFFF" CornerRadius="4"
                            Padding="6,4" Margin="0,4,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="HudActionText" Text="" Foreground="#FFDD00" FontSize="9"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- SETTINGS PANEL -->
            <Border x:Name="SettingsPanel" Grid.Row="2" Visibility="Collapsed" Background="#10FFFFFF" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                <StackPanel>
                    <!-- Opacity slider -->
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Opacity" Foreground="#80FFFFFF" FontSize="9" Width="50" VerticalAlignment="Center"/>
                        <Slider x:Name="SliderOpacity" Style="{StaticResource NeonSlider}" Minimum="0.3" Maximum="1" Value="0.95" ValueChanged="SliderOpacity_Changed"/>
                    </DockPanel>

                    <!-- Blur slider -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Blur" Foreground="#80FFFFFF" FontSize="9" Width="50" VerticalAlignment="Center"/>
                        <Slider x:Name="SliderBlur" Style="{StaticResource NeonSlider}" Minimum="0" Maximum="30" Value="10" ValueChanged="SliderBlur_Changed"/>
                    </DockPanel>

                    <!-- Wake word -->
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Name" Foreground="#80FFFFFF" FontSize="9" Width="50" VerticalAlignment="Center"/>
                        <TextBox x:Name="NameBox" Text="Davos" Style="{StaticResource GlassBox}" FontSize="11" TextChanged="NameBox_TextChanged"/>
                    </DockPanel>

                    <!-- ElevenLabs API Key -->
                    <TextBlock Text="ElevenLabs API Key" Foreground="#80FFFFFF" FontSize="9" Margin="0,0,0,2"/>
                    <TextBox x:Name="ElevenLabsKeyBox" Style="{StaticResource GlassBox}" FontSize="11" Margin="0,0,0,6" TextChanged="ElevenLabsKey_Changed"/>

                    <!-- STT Languages -->
                    <TextBlock Text="STT languages" Foreground="#80FFFFFF" FontSize="9" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox x:Name="SttRuCheck" Content="RU" Style="{StaticResource NeonCheck}" Margin="0,0,8,0" Checked="SttLang_Changed" Unchecked="SttLang_Changed"/>
                        <CheckBox x:Name="SttEnCheck" Content="EN" Style="{StaticResource NeonCheck}" Margin="0,0,8,0" Checked="SttLang_Changed" Unchecked="SttLang_Changed"/>
                        <CheckBox x:Name="SttKkCheck" Content="KK" Style="{StaticResource NeonCheck}" Checked="SttLang_Changed" Unchecked="SttLang_Changed"/>
                    </StackPanel>

                    <!-- Telegram -->
                    <Separator Margin="0,6,0,4" Background="#20FFFFFF"/>
                    <TextBlock Text="TELEGRAM" Foreground="#606070" FontSize="9" FontFamily="Consolas" Margin="0,0,0,4"/>
                    <CheckBox x:Name="TelegramCheck" Content="Enable Telegram (MTProto)" Style="{StaticResource NeonCheck}" Margin="0,0,0,4"
                              Checked="TelegramCheck_Changed" Unchecked="TelegramCheck_Changed"/>
                    <StackPanel x:Name="TelegramFields" Visibility="Collapsed" Margin="0,0,0,2">
                        <TextBlock Text="API ID" Foreground="#80FFFFFF" FontSize="9" Margin="0,0,0,2"/>
                        <TextBox x:Name="TgApiIdBox" Style="{StaticResource GlassBox}" FontSize="11" Margin="0,0,0,4"
                                 TextChanged="TgApiId_Changed"/>
                        <TextBlock Text="API Hash" Foreground="#80FFFFFF" FontSize="9" Margin="0,0,0,2"/>
                        <TextBox x:Name="TgApiHashBox" Style="{StaticResource GlassBox}" FontSize="11" Margin="0,0,0,4"
                                 TextChanged="TgApiHash_Changed"/>
                    </StackPanel>
                    <DockPanel Margin="0,2,0,6">
                        <Button Content="↺ Reset Session" DockPanel.Dock="Right"
                                Style="{StaticResource CleanBtn}" FontSize="8" Padding="6,2"
                                Click="TgResetSession_Click"
                                ToolTip="Delete session file and re-authenticate"
                                Foreground="#80A0B0"/>
                        <TextBlock x:Name="TelegramStatus" Text="● Not configured" Foreground="#506060"
                                   FontSize="9" FontFamily="Consolas" VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Checkboxes -->
                    <CheckBox x:Name="WakeWordCheck" Content="Require wake word" IsChecked="True" Style="{StaticResource NeonCheck}" Margin="0,0,0,4" Checked="WakeWord_Changed" Unchecked="WakeWord_Changed"/>
                    <CheckBox x:Name="AutoMinimizeCheck" Content="Auto-minimize on complete" IsChecked="True" Style="{StaticResource NeonCheck}" Margin="0,0,0,4" Checked="AutoMinimize_Changed" Unchecked="AutoMinimize_Changed"/>
                    <CheckBox x:Name="TtsCheck" Content="Voice responses (Gemini TTS)" Style="{StaticResource NeonCheck}" Margin="0,0,0,6" Checked="Tts_Changed" Unchecked="Tts_Changed"/>

                    <!-- Useful buttons -->
                    <UniformGrid Columns="3" Margin="0,4,0,0">
                        <Button Content="📋 Logs" Style="{StaticResource CleanBtn}" Click="Btn_ShowLogs_Click" FontSize="9"/>
                        <Button Content="🗑️ Clear" Style="{StaticResource CleanBtn}" Click="Btn_ClearChat_Click" FontSize="9"/>
                        <Button Content="🔄 Reset" Style="{StaticResource CleanBtn}" Click="Btn_ResetAudio_Click" FontSize="9" ToolTip="Reset Audio"/>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- CHAT LIST -->
            <ListView x:Name="ChatList" Grid.Row="3" 
                      Background="Transparent" 
                      BorderThickness="0" 
                      Margin="0,2,0,0"
                      Padding="2,2,2,30" 
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.CanContentScroll="False">

                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8" Padding="8,6" Margin="0,0,10,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="HorizontalAlignment" Value="Left"/>
                                    <Setter Property="Background" Value="#12FFFFFF"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Background" Value="#2500FFD1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <TextBlock Text="{Binding Text}" 
                                     TextWrapping="Wrap" 
                                     Foreground="#E8E8E8" 
                                     FontSize="11" 
                                     FontFamily="Segoe UI"/>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- MEMORY PANEL -->
            <Border x:Name="MemoryPanel" Grid.Row="3" Visibility="Collapsed" Background="#08FFFFFF" CornerRadius="6" Margin="0,2,0,0" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="🧠 Memory Bank" Foreground="#00FFD1" FontWeight="Bold" FontSize="10" Margin="0,0,0,6"/>
                    <ListView x:Name="MemoryList" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="10">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#10FFFFFF" CornerRadius="4" Padding="6" Margin="0,1">
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="#D0D0D0" FontSize="10"/>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- TASKS PANEL -->
            <Border x:Name="TasksPanel" Grid.Row="3" Visibility="Collapsed" Background="#08FFFFFF" CornerRadius="6" Margin="0,2,0,0" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="⚡ Running Tasks" Foreground="#00FFD1" FontWeight="Bold" FontSize="10" Margin="0,0,0,6"/>
                    <ListView x:Name="TasksList" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="10">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#10FFFFFF" CornerRadius="4" Padding="6" Margin="0,1">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock Text="{Binding Description}" Foreground="#00FFD1" FontWeight="SemiBold" FontSize="10"/>
                                            <TextBlock Text="{Binding Status}" Foreground="#80FFFFFF" FontSize="9" HorizontalAlignment="Right"/>
                                        </DockPanel>
                                        <TextBlock Text="{Binding Result}" Foreground="#60FFFFFF" FontSize="9" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- INPUT BOX -->
            <Border Grid.Row="4" Background="#12FFFFFF" CornerRadius="10" Padding="2" Margin="0,4,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="InputBox" Style="{StaticResource GlassBox}" FontSize="11"/>
                    <Button Grid.Column="1" Content="➤" Click="Btn_Send_Click" Style="{StaticResource CleanBtn}" Foreground="#00FFD1" Width="30" Height="30" Padding="0"/>
                </Grid>
            </Border>

            <!-- LOG OVERLAY -->
            <Grid x:Name="LogOverlay" Grid.RowSpan="5" Visibility="Collapsed" Background="#F0050505">
                <Border Background="#101010" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="6" Margin="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="8">
                            <TextBlock Text="LOGS" Foreground="#00FFD1" FontWeight="Bold" FontSize="10" VerticalAlignment="Center"/>
                            <Button Content="✕" Click="Btn_CloseLogs_Click" HorizontalAlignment="Right" Style="{StaticResource CleanBtn}" Foreground="#FF5555"/>
                        </DockPanel>
                        <TextBox x:Name="LogTextBox" Grid.Row="1" Background="Transparent" Foreground="#999999" BorderThickness="0"
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="8" IsReadOnly="True" FontFamily="Consolas" FontSize="9"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- PERMISSION OVERLAY -->
            <Grid x:Name="PermissionOverlay" Grid.RowSpan="5" Visibility="Collapsed" Background="#F0050505">
                <Border Background="#151520" BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="8"
                        Padding="16" Margin="20" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="⚠️ Permission Required" Foreground="#FFDD00" FontWeight="Bold" FontSize="12" Margin="0,0,0,10"/>
                        <TextBlock x:Name="PermissionActionText" Text="" Foreground="White" FontSize="11" TextWrapping="Wrap"/>
                        <TextBlock x:Name="PermissionDetailsText" Text="" Foreground="#80FFFFFF" FontSize="10"
                                   TextWrapping="Wrap" Margin="0,6,0,12"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="✓ Allow" Click="Btn_PermissionAllow_Click"
                                    Style="{StaticResource CleanBtn}" Background="#2000FF00" Margin="0,0,10,0" Padding="16,8"/>
                            <Button Content="✕ Deny" Click="Btn_PermissionDeny_Click"
                                    Style="{StaticResource CleanBtn}" Background="#20FF0000" Padding="16,8"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>