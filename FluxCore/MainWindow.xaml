<Window x:Class="FluxCore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FluxCore" Height="Auto" Width="480"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" SizeToContent="Height">

    <Window.Resources>
        <Style x:Key="ModernBtn" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Shadow" Background="Black" CornerRadius="14" Opacity="0.2" Margin="0,2,0,0"/>
                            <Border x:Name="Body" Background="#20FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="14">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15,0"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Body" Property="Background" Value="#35FFFFFF"/>
                                <Setter TargetName="Body" Property="BorderBrush" Value="#60FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Body" Property="Background" Value="#10FFFFFF"/>
                                <Setter TargetName="Shadow" Property="Margin" Value="0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track Name="PART_Track" IsDirectionReversed="true">
                            <Track.Thumb>
                                <Thumb Background="#40FFFFFF"/>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" 
            Background="#F2121212" 
            CornerRadius="28" 
            BorderBrush="#25FFFFFF" 
            BorderThickness="1.2" 
            Margin="25"
            Padding="20"
            RenderTransformOrigin="0.5,0">
        <Border.RenderTransform>
            <TranslateTransform x:Name="PanelTransform" Y="-20"/>
        </Border.RenderTransform>

        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.7" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="25"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Name="ButtonContainer" Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" MouseLeftButtonDown="Window_MouseLeftButtonDown"/>

            <ScrollViewer Name="ChatScroller" Grid.Row="2" MaxHeight="400" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl Name="ChatList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,8,0,8">
                                <Border Name="Bubble" Padding="16,12" MaxWidth="320">
                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Foreground="White" FontSize="15" LineHeight="22">
                                        <TextBlock.Effect>
                                            <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.4"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                </Border>
                            </Grid>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                    <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right"/>
                                    <Setter TargetName="Bubble" Property="Background" Value="#0078D4"/>
                                    <Setter TargetName="Bubble" Property="CornerRadius" Value="18,18,4,18"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsUser}" Value="False">
                                    <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Left"/>
                                    <Setter TargetName="Bubble" Property="Background" Value="#2D2D2D"/>
                                    <Setter TargetName="Bubble" Property="CornerRadius" Value="18,18,18,4"/>
                                    <Setter TargetName="Bubble" Property="BorderBrush" Value="#20FFFFFF"/>
                                    <Setter TargetName="Bubble" Property="BorderThickness" Value="1"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>