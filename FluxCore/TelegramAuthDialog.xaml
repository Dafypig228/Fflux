<Window x:Class="FluxCore.TelegramAuthDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Telegram Auth" Height="160" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1A1A21"
        Foreground="White"
        FontFamily="Consolas">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Grid.Row="0"
                   Text="Enter value:"
                   Foreground="#AAB0C0"
                   FontSize="12"
                   TextWrapping="Wrap"/>

        <TextBox x:Name="AnswerBox" Grid.Row="2"
                 Background="#0D0D14"
                 Foreground="White"
                 BorderBrush="#304050"
                 BorderThickness="1"
                 Padding="6,4"
                 FontSize="12"
                 CaretBrush="White"
                 KeyDown="AnswerBox_KeyDown"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click"
                    Background="#20303F" Foreground="#80A0B0"
                    BorderBrush="#304050" BorderThickness="1"
                    Padding="12,4" Margin="0,0,8,0" Cursor="Hand"/>
            <Button Content="OK" Click="Ok_Click"
                    Background="#00887A" Foreground="White"
                    BorderThickness="0"
                    Padding="16,4" Cursor="Hand"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
